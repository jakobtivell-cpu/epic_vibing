# Copy to .env if your tooling loads it. The core scraper does not require a .env file.

# Express dashboard (server.ts)
PORT=3000

# Optional: absolute path to app root (output/, downloads/, data/). Used by src/config/settings.ts when set.
# APP_ROOT=

# Required for IR health check workflow (scripts/ir-health-check.mjs)
ANTHROPIC_API_KEY=

# Optional, for LLM challenger mode (src/challenger/*)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Documented for tooling; not read by scrape.ts yet — use --slow / --verbose today
INTER_COMPANY_DELAY_MS=2000
LOG_LEVEL=info
